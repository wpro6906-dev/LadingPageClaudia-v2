# ─── Base de datos ───────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Render Postgres, etc.)
# Ejemplo Neon:    postgres://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
# Ejemplo Supabase: postgres://postgres:pass@db.xxx.supabase.co:5432/postgres
DATABASE_URL=

# ─── Autenticación JWT ───────────────────────────────────────────────────────
# Secreto para firmar los tokens JWT. Genera uno fuerte con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ─── Admin por defecto ───────────────────────────────────────────────────────
# Credenciales del administrador. Se crean/sincronizan automáticamente al arrancar.
# Cambia ADMIN_PASSWORD aquí y reinicia para actualizar la contraseña sin tocar la DB.
ADMIN_USERNAME=ClaudiaAlzate
ADMIN_PASSWORD=Claudia321

# ─── CORS ────────────────────────────────────────────────────────────────────
# Orígenes adicionales permitidos (separados por coma).
# Los dominios *.vercel.app, *.onrender.com, *.replit.dev ya están permitidos.
# Ejemplo: ALLOWED_ORIGINS=https://claudia.com,https://www.claudia.com
ALLOWED_ORIGINS=

# ─── Entorno ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
